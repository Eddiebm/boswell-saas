# App
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Optional: owner bootstrap without OAuth app (from `gh auth token`)
GITHUB_BOOTSTRAP_TOKEN=

# Database (Neon)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Boswell engine / audits
OPENROUTER_API_KEY=
BOSWELL_ENGINE_GIT_URL=git+https://github.com/Eddiebm/boswell.git

# Worker
WORKER_SECRET=change-me

# Failure alerts (Resend)
ADMIN_ALERT_EMAIL=
RESEND_API_KEY=
ALERT_FROM_EMAIL=Boswell <onboarding@resend.dev>

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
